# ─── AgriTrace Frontend — Environment Variables ──────────────────────────────
#
# Copy this file to .env and fill in the values for your environment.
# VITE_ prefixed vars are embedded into the browser bundle at build time.
# Non-prefixed vars (BACKEND_URL) are only read by vite.config.js at dev time.

# ─── Development ─────────────────────────────────────────────────────────────

# Port your Express backend listens on (used by the Vite dev proxy).
# Leave empty to use the default: http://localhost:4000
BACKEND_URL=http://localhost:4000

# Leave VITE_API_URL empty in development — requests will be forwarded
# by the Vite proxy above (no CORS issues, no absolute URL needed).
VITE_API_URL=

# ─── Production ──────────────────────────────────────────────────────────────

# Set this to the full backend origin in production builds.
# The browser bundle will use this URL directly for all /api requests.
# Example: VITE_API_URL=https://api.agritrace.example.com
# VITE_API_URL=
