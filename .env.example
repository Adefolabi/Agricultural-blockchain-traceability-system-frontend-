# Copy this file to .env.local for local overrides (never commit .env.local).
#
# VITE_API_BASE_URL
#   Leave empty in development — the Vite dev server proxies /api/* to localhost:3000.
#   Set to your backend's public URL when deploying to Vercel or any other host.
#
# Example (local dev — leave blank or omit the file entirely):
# VITE_API_BASE_URL=
#
# Example (production backend on Render / Railway / a VPS):
# VITE_API_BASE_URL=https://agritrace-api.onrender.com

VITE_API_BASE_URL=
